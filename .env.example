# Bestellsystem Environment Configuration
# Copy this file to .env and set your production values

# Master PIN für System-Zugriff (4-8 Ziffern)
# Standard: 22822282 (nur für Entwicklung!)
# In Produktion MUSS dieser Wert geändert werden!
MASTER_PIN=22822282

# Server Port (Standard: 3000)
# PORT=3000

# HTTPS Port (Standard: 3443)
# HTTPS_PORT=3443
